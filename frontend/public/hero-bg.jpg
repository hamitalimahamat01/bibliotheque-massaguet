<svg xmlns="http://www.w3.org/2000/svg" width="1920" height="600" viewBox="0 0 1920 600">
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4f46e5;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#7c3aed;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#06b6d4;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="1920" height="600" fill="url(#grad)"/>
  <g opacity="0.1">
    <circle cx="200" cy="100" r="80" fill="white"/>
    <circle cx="400" cy="300" r="60" fill="white"/>
    <circle cx="1500" cy="150" r="100" fill="white"/>
    <circle cx="1700" cy="400" r="70" fill="white"/>
  </g>
  <text x="960" y="320" font-family="Arial" font-size="60" fill="white" text-anchor="middle" opacity="0.5">Bibliothèque Massaguet</text>
</svg>
